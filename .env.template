# ---------------------------------------------------------------------------
# Stripe — v1.8.0 BonBeauty live payment backend (ADR-100 / ADR-101 / ADR-120)
# ---------------------------------------------------------------------------
# v1.9.0 wf5 (closes CC-1 F-CC1-013): per-market env vars REQUIRED for any
# market listed in `STRIPE_ENABLED_MARKETS` (backend market-resolver.ts).
# Naming convention: STRIPE_<TYPE>_KEY_<MARKET_UPPER>.
# Replace BONBEAUTY with the uppercase market id for additional markets.
STRIPE_SECRET_KEY_BONBEAUTY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_KEY_BONBEAUTY=whsec_REPLACE_ME
# Publishable key is read by the storefront via NEXT_PUBLIC_STRIPE_KEY_BONBEAUTY;
# the backend SecretsAdapter signature also accepts `publishable` (reserved
# for GcpSecretsAdapter v1.10.0+).
STRIPE_PUBLISHABLE_KEY_BONBEAUTY=pk_test_REPLACE_ME

# Brevo inbound webhook signature validation (Story 5.10).
# Local/dev placeholder only. Do not commit real Brevo HMAC secrets.
BREVO_HMAC_SECRET=<your-brevo-hmac-secret>

# Secrets adapter selection. Default `env` reads process.env directly.
# `gcp` is v1.10.0+ production posture (Google Cloud Secret Manager).
SECRETS_ADAPTER=env
