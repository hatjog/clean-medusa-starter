# Backend env example additions.
# Full backend template lives in .env.template; this file declares the Story 5.10
# Brevo webhook HMAC secret expected by security middleware.
BREVO_HMAC_SECRET=<your-brevo-hmac-secret>

# Apple Wallet pozostaje domyślnie wyłączony w v1.10.0.
WALLET_APPLE_ENABLED=false

# Produkcyjne dane podpisywania Apple należy dodać dopiero po enrollment
# i tylko przez secret store w slocie v1.11.0+.
