{
  "name": "@gp/api",
  "version": "0.0.1",
  "private": true,
  "description": "GP backend (Medusa + Mercur) — Phase A1 rebase target per ADR-090/091/092.",
  "license": "MIT",
  "keywords": [
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa",
    "mercur"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "db:migrate:app": "ts-node ./packages/api/src/scripts/run-app-migrations.ts",
    "db:migrate:app:status": "ts-node ./packages/api/src/scripts/run-app-migrations.ts status",
    "db:migrate:legacy-base": "GP_MIGRATION_SURFACE=legacy-base ts-node ./packages/api/src/scripts/run-app-migrations.ts",
    "db:migrate:legacy-base:status": "GP_MIGRATION_SURFACE=legacy-base ts-node ./packages/api/src/scripts/run-app-migrations.ts status",
    "db:migrate:all": "medusa db:migrate && pnpm run db:migrate:app",
    "typecheck": "tsc --noEmit",
    "mcp": "ts-node ./mcp/server.ts",
    "gp-config-mcp": "ts-node ./mcp/gp-config-mcp.ts",
    "gp-market-storefront-key": "ts-node ./mcp/gp-market-storefront-key.ts",
    "seed": "medusa exec ./packages/api/src/scripts/seed.ts",
    "commission-smoke": "medusa exec ./packages/api/src/scripts/commission-smoke.ts",
    "gp-fix-legacy-commission-schema": "ts-node ./packages/api/src/scripts/gp-fix-legacy-commission-schema.ts",
    "gp-config-sync-catalog": "medusa exec ./packages/api/src/scripts/gp-config-sync-catalog.ts",
    "gp-config-sync-orchestrator": "medusa exec ./packages/api/src/scripts/gp-config-sync-orchestrator.ts",
    "gp-config-sync-shipping": "medusa exec ./packages/api/src/scripts/gp-config-sync-shipping.ts",
    "gp-config-sync-payments": "medusa exec ./packages/api/src/scripts/gp-config-sync-payments.ts",
    "gp-config-sync-media": "medusa exec ./packages/api/src/scripts/gp-config-sync-media.ts",
    "gp-config-sync-accounts": "medusa exec ./packages/api/src/scripts/gp-config-sync-accounts.ts",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:patches": "TEST_TYPE=patches NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/ui": "4.0.25",
    "@mercurjs/cli": "2.1.1",
    "@mercurjs/commission": "1.5.3",
    "@mercurjs/core": "2.1.1",
    "@mercurjs/types": "2.1.1",
    "@sentry/node": "^9.0.0",
    "awilix": "^8.0.1",
    "http-proxy-middleware": "^3.0.5",
    "js-yaml": "^4.1.1",
    "posthog-node": "^5.11.0",
    "resend": "^4.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.6",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=22.17.0",
    "pnpm": ">=9"
  }
}
