# Google Wallet (Story 3.2) — Demo Issuer dla BonBeauty pilot.
# .env.local dopuszczalne w v1.10.0; GCP Secret Manager class google_wallet
# pozostaje docelowym zrodlem po aktywacji D-100. Nie commituj live key.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
GOOGLE_WALLET_CLASS_ID_TEMPLATE={issuer_id}.{market_code}_voucher_v1
GOOGLE_WALLET_MARKET_CODE=bonbeauty
GOOGLE_WALLET_ISSUER_NAME=Grow Platform
GOOGLE_WALLET_REQUEST_TIMEOUT_MS=2000
